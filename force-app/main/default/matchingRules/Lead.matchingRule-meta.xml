<?xml version="1.0" encoding="UTF-8"?>
<MatchingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <matchingRules>
        <fullName>Lead_Dedup_Mobile_Product</fullName>
        <label>Lead Dedup by Mobile and Product</label>
        <matchingRuleItems>
            <blankValueBehavior>NullNotAllowed</blankValueBehavior>
            <fieldName>MobilePhone</fieldName>
            <matchingMethod>Exact</matchingMethod>
        </matchingRuleItems>
        <matchingRuleItems>
            <blankValueBehavior>NullNotAllowed</blankValueBehavior>
            <fieldName>Product__c</fieldName>
            <matchingMethod>Exact</matchingMethod>
        </matchingRuleItems>
        <booleanFilter>1 AND 2</booleanFilter>
        <description>Matches leads with same MobilePhone AND same Product. Used to block same-product duplicates.</description>
        <ruleStatus>Active</ruleStatus>
    </matchingRules>
    <matchingRules>
        <fullName>Lead_Dedup_Mobile_Only</fullName>
        <label>Lead Dedup by Mobile Only</label>
        <matchingRuleItems>
            <blankValueBehavior>NullNotAllowed</blankValueBehavior>
            <fieldName>MobilePhone</fieldName>
            <matchingMethod>Exact</matchingMethod>
        </matchingRuleItems>
        <description>Matches leads with same MobilePhone only. Used to detect cross-product customers.</description>
        <ruleStatus>Active</ruleStatus>
    </matchingRules>
</MatchingRules>
